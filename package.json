{
  "name": "lazy-pi",
  "version": "0.1.3",
  "description": "You love LazyVim. You're gonna love LazyPi.",
  "type": "module",
  "files": [
    "src",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "src/index.ts"
    ]
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.67.68",
    "@mariozechner/pi-tui": "^0.67.4"
  },
  "keywords": [
    "pi-package",
    "lazy-pi",
    "pi-extension",
    "package-manager"
  ],
  "license": "MIT",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alpha-innovation-labs/lazy-pi.git"
  },
  "bugs": {
    "url": "https://github.com/alpha-innovation-labs/lazy-pi/issues"
  },
  "homepage": "https://github.com/alpha-innovation-labs/lazy-pi#readme"
}
